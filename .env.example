# Mimir MCP Server
# Copy to .env and fill in your keys

# Required for LLM extraction (entity/relationship detection)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for semantic search (embedding generation)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the extraction model (default: claude-haiku-4-5-20251001)
# MIMIR_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Optional: override data path (default: /Volumes/AI-Lab/falkordb-data/personal-brain)
# MIMIR_DATA_PATH=/path/to/your/falkordb-data
