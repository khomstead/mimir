<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.speki.mimir</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/kyle/.bun/bin/bun</string>
        <string>run</string>
        <string>/Volumes/AI-Lab/Projects/mimir/src/service.ts</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Volumes/AI-Lab/Projects/mimir</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/kyle/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>MIMIR_DATA_PATH</key>
        <string>/Volumes/AI-Lab/falkordb-data/personal-brain</string>
        <key>MIMIR_PORT</key>
        <string>4200</string>
    </dict>

    <!-- Start at boot, restart on crash -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Volumes/AI-Lab/logs/mimir-service.log</string>
    <key>StandardErrorPath</key>
    <string>/Volumes/AI-Lab/logs/mimir-service.log</string>
</dict>
</plist>
